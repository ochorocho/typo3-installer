#!/usr/bin/env bash

## Description: Run Playwright SQLite full-flow test against remote servers (uses the DDEV Playwright container, which already has browsers + deps preinstalled)
## Usage: playwright-remote [host]
## Example: "ddev playwright-remote" (test all configured servers)
## Example: "ddev playwright-remote ftp.example.com" (test specific host only)

set -euo pipefail

PROJECT_ROOT="${DDEV_APPROOT:-$(pwd)}"
CONFIG_FILE="$PROJECT_ROOT/.deploy-servers.json"
FILTER_HOST="${1:-}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

info()  { echo -e "${GREEN}[INFO]${NC} $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $*"; }
error() { echo -e "${RED}[ERROR]${NC} $*"; }

# ------------------------------------------------------------------
# Dependency checks (host)
# ------------------------------------------------------------------
for cmd in curl jq ddev; do
    if ! command -v "$cmd" &>/dev/null; then
        error "Required command '$cmd' is not installed on the host."
        exit 1
    fi
done

# ------------------------------------------------------------------
# Config validation
# ------------------------------------------------------------------
if [[ ! -f "$CONFIG_FILE" ]]; then
    error "Config file not found: $CONFIG_FILE"
    echo "  Copy .deploy-servers.example.json to .deploy-servers.json and fill in your server details."
    exit 1
fi

if ! jq empty "$CONFIG_FILE" 2>/dev/null; then
    error "Invalid JSON in $CONFIG_FILE"
    exit 1
fi

SERVER_COUNT=$(jq 'length' "$CONFIG_FILE")
if [[ "$SERVER_COUNT" -eq 0 ]]; then
    warn "No servers defined in $CONFIG_FILE — nothing to do."
    exit 0
fi

# Filter to servers with playwright_url (and optionally by host)
if [[ -n "$FILTER_HOST" ]]; then
    TESTABLE=$(jq --arg host "$FILTER_HOST" '[.[] | select(.playwright_url and .playwright_url != "" and .host == $host)]' "$CONFIG_FILE")
else
    TESTABLE=$(jq '[.[] | select(.playwright_url and .playwright_url != "")]' "$CONFIG_FILE")
fi
TESTABLE_COUNT=$(echo "$TESTABLE" | jq 'length')

if [[ "$TESTABLE_COUNT" -eq 0 ]]; then
    if [[ -n "$FILTER_HOST" ]]; then
        warn "No testable server found matching host '$FILTER_HOST'."
    else
        warn "No servers with 'playwright_url' configured — nothing to test."
    fi
    exit 0
fi

if [[ -n "$FILTER_HOST" ]]; then
    info "Running remote Playwright test against host '$FILTER_HOST'…"
else
    info "Running remote Playwright tests against $TESTABLE_COUNT server(s)…"
fi
echo

# ------------------------------------------------------------------
# Test loop
# ------------------------------------------------------------------
SUCCESS=0
FAIL=0
SKIPPED=0

for i in $(seq 0 $((TESTABLE_COUNT - 1))); do
    HOST=$(echo "$TESTABLE" | jq -r ".[$i].host")
    NUKE_URL=$(echo "$TESTABLE" | jq -r ".[$i].nuke_url // empty")
    PLAYWRIGHT_URL=$(echo "$TESTABLE" | jq -r ".[$i].playwright_url")
    BASE_URL="${PLAYWRIGHT_URL%/typo3-installer.php}"

    echo "──────────────────────────────────────────"
    info "Server: $HOST"
    info "  URL: $PLAYWRIGHT_URL"

    # Preflight: if the nuke URL is unreachable, skip this host instead of
    # timing out 5 min inside Playwright waiting for a fresh wizard.
    if [[ -n "$NUKE_URL" && "$NUKE_URL" != "null" ]]; then
        NUKE_HTTP=$(curl -s -o /dev/null -w "%{http_code}" \
            -u "nuke:Password.1" --connect-timeout 15 --max-time 60 \
            "$NUKE_URL" || echo "000")
        if [[ ! "$NUKE_HTTP" =~ ^2 ]]; then
            warn "  ⚠ SKIPPED: $HOST — nuke URL returned HTTP $NUKE_HTTP"
            SKIPPED=$((SKIPPED + 1))
            echo
            continue
        fi
    fi

    # Per-host output directories (paths as seen from inside the container —
    # /var/www/html is the project root, bind-mounted)
    CONTAINER_HOST_DIR="/var/www/html/tests/e2e/$HOST"
    HOST_HOST_DIR="$PROJECT_ROOT/tests/e2e/$HOST"
    mkdir -p "$HOST_HOST_DIR"

    # Build env vars + container NUKE_URL value (empty if unset)
    CONTAINER_NUKE_URL=""
    if [[ -n "$NUKE_URL" && "$NUKE_URL" != "null" ]]; then
        CONTAINER_NUKE_URL="$NUKE_URL"
    fi

    info "  Running SQLite full-flow test in playwright container (BASE_URL='$BASE_URL')…"

    # Dispatch the test into the playwright service container, which is
    # based on the official mcr.microsoft.com/playwright image — browsers
    # and OS deps are already installed, so we skip `playwright install-deps`
    # and `playwright install` entirely.
    if ddev exec -d /var/www/html/tests/e2e -s playwright env \
            BASE_URL="$BASE_URL" \
            REMOTE_TEST=true \
            NUKE_URL="$CONTAINER_NUKE_URL" \
            PLAYWRIGHT_HTML_REPORT="$CONTAINER_HOST_DIR/playwright-report" \
            PLAYWRIGHT_HTML_OPEN=never \
            PLAYWRIGHT_JUNIT_OUTPUT_NAME="$CONTAINER_HOST_DIR/junit.xml" \
            npx playwright test \
                --project=sqlite \
                --output="$CONTAINER_HOST_DIR/test-results" \
                tests/full-flows/sqlite.spec.js; then
        info "  ✓ PASSED: $HOST"
        SUCCESS=$((SUCCESS + 1))
    else
        error "  ✗ FAILED: $HOST"
        FAIL=$((FAIL + 1))
    fi

    echo
done

# ------------------------------------------------------------------
# Summary
# ------------------------------------------------------------------
echo "══════════════════════════════════════════"
info "Remote tests complete: ${GREEN}${SUCCESS} passed${NC}, ${RED}${FAIL} failed${NC}, ${YELLOW}${SKIPPED} skipped${NC} (of $TESTABLE_COUNT)"
[[ "$FAIL" -gt 0 ]] && exit 1
exit 0
