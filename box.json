{
    "chmod": "0755",
    "compression": "GZ",
    "output": "typo3-installer.phar",
    "stub": "stub.php",
    "main": "src/bootstrap.php",
    "directories": [
        "src",
        "public"
    ],
    "finder": [
        {
            "name": "*.php",
            "exclude": [
                "Tests",
                "tests",
                "humbug",
                "node_modules",
                "test-installer-root"
            ],
            "in": "vendor"
        }
    ],
    "blacklist": [
        "vendor/humbug"
    ],
    "exclude-composer-files": true,
    "exclude-dev-files": true
}
