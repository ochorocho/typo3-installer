{
    "alias": "typo3-installer.php",
    "compression": "GZ",
    "output": "typo3-installer.phar",
    "check-requirements": false,
    "stub": "stub.php",
    "main": "src/bootstrap.php",
    "directories": [
        "src",
        "public",
        "vendor/symfony/console/Resources"
    ],
    "files": [
        "resources/composer.phar"
    ],
    "finder": [
        {
            "name": "*.php",
            "exclude": [
                "Tests",
                "tests",
                "humbug",
                "jetbrains",
                "phpstan"
            ],
            "notPath": [
                "vendor/humbug"
            ],
            "in": "vendor"
        }
    ],
    "blacklist": [
        "vendor/humbug"
    ],
    "dump-autoload": true
}
