{
    "compression": "GZ",
    "output": "typo3-installer.phar",
    "stub": "stub.php",
    "main": "src/bootstrap.php",
    "directories": [
        "src",
        "public",
        "vendor/symfony/console/Resources",
        "vendor/composer/composer/res",
        "vendor/composer/spdx-licenses/res"
    ],
    "files": [
        "vendor/composer/composer/LICENSE"
    ],
    "finder": [
        {
            "name": "*.php",
            "exclude": [
                "Tests",
                "tests",
                "humbug",
                "jetbrains"
            ],
            "in": "vendor"
        }
    ],
    "blacklist": [
        "vendor/humbug"
    ]
}
